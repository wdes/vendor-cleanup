#!/usr/bin/env python3
"""
vendor-cleanup: open .gitattributes export-ignore PRs at scale.

Reads a YAML config that lists repos, the entries to add, and metadata for
the PR body. Performs three pre-flight checks before opening each PR:

  1. Idempotency:   skip if a PR already exists on USER:BRANCH for that repo.
  2. Rejection:     skip if a non-author closed a similar PR in the last 5y.
  3. Upstream:      drop entries whose paths no longer exist in upstream HEAD.

Then forks/clones, modifies .gitattributes (with sort + alignment style
preservation), commits, pushes, opens the PR. Random 10-20s sleep between PRs.

Usage:
    vendor-cleanup --config CONFIG.yaml         # dry-run preview
    vendor-cleanup --config CONFIG.yaml --go    # actually open PRs
    vendor-cleanup --config CONFIG.yaml --go --limit 3
"""
from __future__ import annotations
import argparse
import datetime as dt
import json
import os
import random
import re
import subprocess
import sys
import time
from dataclasses import dataclass, field
from pathlib import Path

import yaml


# ---------- helpers ----------

def run(cmd: list[str], cwd: Path | str | None = None, check: bool = True, capture: bool = False) -> subprocess.CompletedProcess:
    r = subprocess.run(cmd, cwd=cwd, capture_output=capture, text=True)
    if check and r.returncode != 0:
        msg = r.stderr if capture else ""
        raise RuntimeError(f"command failed ({' '.join(cmd)}): {msg}")
    return r


def gh_json(args: list[str]) -> dict | list | None:
    r = subprocess.run(["gh", "api", *args], capture_output=True, text=True, timeout=60)
    if r.returncode != 0:
        return None
    try:
        return json.loads(r.stdout)
    except json.JSONDecodeError:
        return None


def gh_pr_list(repo: str, head_branch: str, owner: str, state: str = "all") -> int:
    """Return count of PRs from owner:branch (head) against repo."""
    r = subprocess.run(
        ["gh", "pr", "list", "--repo", repo, "--state", state,
         "--json", "number,headRefName,headRepositoryOwner",
         "--jq", f'[.[] | select(.headRefName == "{head_branch}" and .headRepositoryOwner.login == "{owner}")] | length'],
        capture_output=True, text=True, timeout=30,
    )
    try:
        return int(r.stdout.strip() or "0")
    except ValueError:
        return 0


# ---------- pre-flight checks ----------

def check_upstream_exists(repo: str, branch: str, path: str) -> bool:
    """True if `path` exists at repo@branch."""
    r = subprocess.run(
        ["gh", "api", "-i", f"repos/{repo}/contents/{path}?ref={branch}"],
        capture_output=True, text=True, timeout=30,
    )
    return "200 OK" in (r.stdout.split("\n", 1)[0] if r.stdout else "")


def check_rejection_history(repo: str, owner: str, max_age_years: int = 5) -> str | None:
    """Return a rejection signal (PR ref) if found, else None."""
    now_year = dt.date.today().year
    closed = gh_json(["-X", "GET", f"search/issues",
                      "-f", f"q=is:pr+repo:{repo}+author:!{owner}+state:closed+is:unmerged+.gitattributes",
                      "-f", "per_page=20"])
    if not closed or "items" not in closed:
        # fallback to title/body search
        r = subprocess.run(
            ["gh", "pr", "list", "--repo", repo, "--state", "closed",
             "--search", "gitattributes OR export-ignore",
             "--json", "number,author,closedAt,mergedAt,state"],
            capture_output=True, text=True, timeout=30,
        )
        try:
            items = [p for p in json.loads(r.stdout) if p["state"] == "CLOSED" and not p.get("mergedAt")]
        except (json.JSONDecodeError, KeyError):
            return None
    else:
        items = [{"number": i["number"], "author": {"login": i["user"]["login"]},
                  "closedAt": i["closed_at"], "mergedAt": i.get("pull_request", {}).get("merged_at"), "state": "CLOSED"}
                 for i in closed["items"] if not i.get("pull_request", {}).get("merged_at")]

    for pr in items:
        if not pr.get("closedAt"):
            continue
        closed_year = int(pr["closedAt"][:4])
        if now_year - closed_year > max_age_years:
            continue
        # must touch .gitattributes
        files_res = subprocess.run(
            ["gh", "pr", "view", str(pr["number"]), "--repo", repo,
             "--json", "files", "--jq", '[.files[].path] | any(. == ".gitattributes")'],
            capture_output=True, text=True, timeout=30,
        )
        if files_res.stdout.strip() != "true":
            continue
        # who closed?
        timeline = gh_json([f"repos/{repo}/issues/{pr['number']}/timeline"])
        if not isinstance(timeline, list):
            continue
        closer = None
        for ev in reversed(timeline):
            if isinstance(ev, dict) and ev.get("event") == "closed":
                actor = ev.get("actor") or {}
                closer = actor.get("login")
                break
        author = (pr.get("author") or {}).get("login") if isinstance(pr.get("author"), dict) else pr.get("author")
        if not closer or closer == author or closer == owner:
            continue
        return f"#{pr['number']} closed by {closer} on {pr['closedAt'][:10]}"
    return None


# ---------- style detection ----------

def detect_style(content: str) -> tuple[bool, int]:
    """Return (sorted_alphabetically, align_col).
       align_col is 0 if no alignment detected."""
    lines = [ln for ln in content.splitlines() if re.search(r"\s+export-ignore\s*$", ln)]
    if not lines:
        return False, 0
    stripped = [re.sub(r"^/|/$", "", ln.split()[0]) for ln in lines]
    sorted_flag = stripped == sorted(stripped)
    cols = [ln.find("export-ignore") for ln in lines]
    col_freq: dict[int, int] = {}
    for c in cols:
        col_freq[c] = col_freq.get(c, 0) + 1
    top_col, top_count = max(col_freq.items(), key=lambda kv: kv[1])
    distinct_lens = len({len(s) for s in (ln.split()[0] for ln in lines)})
    align_col = top_col if top_count >= 2 and distinct_lens >= 2 else 0
    return sorted_flag, align_col


def add_with_style(content: str, lines_to_add: list[str], sorted_flag: bool, align_col: int) -> str:
    """Append lines_to_add to content, respecting style. Returns new content."""
    existing_paths = set()
    for ln in content.splitlines():
        m = re.match(r"^\s*/?([^\s]+?)/?\s+export-ignore\s*$", ln)
        if m:
            existing_paths.add(m.group(1).strip("/"))

    new_lines = []
    for raw in lines_to_add:
        key = raw.split()[0]
        norm = key.strip("/")
        if norm in existing_paths:
            continue
        if align_col > 0:
            pad = max(1, align_col - len(key) - 1)
            new_lines.append(f"{key}{' ' * pad}export-ignore")
        else:
            new_lines.append(raw)
        existing_paths.add(norm)

    body = content if content.endswith("\n") or not content else content + "\n"
    body += "\n".join(new_lines) + ("\n" if new_lines else "")

    if sorted_flag and new_lines:
        all_lines = body.splitlines()
        ei = [ln for ln in all_lines if re.search(r"\s+export-ignore\s*$", ln)]
        other = [ln for ln in all_lines if not re.search(r"\s+export-ignore\s*$", ln)]
        ei.sort(key=lambda s: re.sub(r"^/|/$", "", s.split()[0]))
        body = "\n".join(other + ei) + "\n"
    return body


# ---------- PR body ----------

def build_pr_body(last_ga_ref: str, entries: list[dict]) -> str:
    body = (
        "This avoids shipping dev/tooling files in the composer dist that "
        "aren't needed at runtime.\n\n"
        f"Last `.gitattributes` update was {last_ga_ref}. The files below "
        "have been added or modified since, and are still included in the "
        "composer dist:\n"
    )
    for e in entries:
        body += f"- `{e['line']}` - last touched in {e['ref']}\n"
    body += "\nBackground reading: https://blog.madewithlove.be/post/gitattributes/"
    return body


def commit_trailer(repo: str) -> str:
    org = repo.split("/", 1)[0].lower()
    cla_orgs = {"googlecloudplatform", "googleapis", "google"}
    if org in cla_orgs:
        return "Drafted with assistance from Claude Code (https://claude.com/claude-code)."
    return "Co-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>"


# ---------- main ----------

@dataclass
class Defaults:
    fork_dir: Path = Path.home() / "forks"
    user_login: str = "you"
    branch: str = "you/gitattributes-export-ignore"
    pr_title: str = "Update .gitattributes to exclude dev files from composer dist"
    sleep_min: int = 10
    sleep_max: int = 20


def process_target(t: dict, defaults: Defaults, dry_run: bool) -> str:
    repo = t["repo"]
    branch = t.get("branch", "main")
    entries = t.get("entries", [])
    last_ga = t.get("last_gitattributes_ref", "N/A")
    create = bool(t.get("create", False))

    print(f">>> {repo}  (base={branch}, entries={len(entries)})")

    # 1. Idempotency
    if gh_pr_list(repo, defaults.branch, defaults.user_login) >= 1:
        return "skipped: PR already exists"

    # 2. Rejection history
    rej = check_rejection_history(repo, defaults.user_login)
    if rej:
        return f"skipped: rejection history ({rej})"

    # 3. Upstream existence
    surviving = []
    for e in entries:
        path = e["line"].split()[0].strip("/")
        if e.get("ref") == "new" or check_upstream_exists(repo, branch, path):
            surviving.append(e)
        else:
            print(f"    ! dropping `{e['line']}` (not in upstream)")
    if not surviving:
        return "skipped: nothing remains after upstream check"

    pr_body = build_pr_body(last_ga, surviving)

    if dry_run:
        action = "CREATE" if create else "APPEND"
        print(f"    file action: {action} .gitattributes")
        for e in surviving:
            print(f"        + {e['line']}    [{e['ref']}]")
        print(f"    --- PR title ---\n    {defaults.pr_title}")
        print(f"    --- PR body ---")
        for line in pr_body.split("\n"):
            print(f"    {line}")
        return "dry-run"

    # 4. Fork + clone
    fork_name = repo.split("/", 1)[1]
    local_dir = defaults.fork_dir / fork_name
    r = subprocess.run(["gh", "repo", "view", f"{defaults.user_login}/{fork_name}"],
                       capture_output=True)
    if r.returncode != 0:
        run(["gh", "repo", "fork", repo, "--clone=false", "--default-branch-only"])
        time.sleep(3)

    if not local_dir.exists():
        run(["git", "clone", f"git@github.com:{defaults.user_login}/{fork_name}.git", str(local_dir)])

    # 5. Branch from upstream
    r = subprocess.run(["git", "-C", str(local_dir), "remote", "get-url", "upstream"],
                       capture_output=True)
    if r.returncode != 0:
        run(["git", "-C", str(local_dir), "remote", "add", "upstream", f"git@github.com:{repo}.git"])
    run(["git", "-C", str(local_dir), "fetch", "upstream", branch])
    run(["git", "-C", str(local_dir), "checkout", "-B", defaults.branch, f"upstream/{branch}"])

    # 6. Modify .gitattributes (with style preservation)
    ga = local_dir / ".gitattributes"
    if create or not ga.exists():
        content = ""
        sorted_flag, align_col = False, 0
    else:
        content = ga.read_text()
        sorted_flag, align_col = detect_style(content)
        print(f"    style: sorted={int(sorted_flag)} align_col={align_col}")

    new_content = add_with_style(content, [e["line"] for e in surviving], sorted_flag, align_col)
    if new_content == content and not create:
        return "skipped: no diff after dedup"
    ga.write_text(new_content)

    # 7. Commit + push + PR
    trailer = commit_trailer(repo)
    msg = f"{defaults.pr_title}\n\n{pr_body}\n\n{trailer}"
    run(["git", "-C", str(local_dir), "add", ".gitattributes"])
    run(["git", "-C", str(local_dir), "commit", "-m", msg])
    run(["git", "-C", str(local_dir), "push", "-u", "origin", defaults.branch])

    pr_url = subprocess.run(
        ["gh", "pr", "create", "--repo", repo, "--base", branch,
         "--head", f"{defaults.user_login}:{defaults.branch}",
         "--title", defaults.pr_title, "--body", pr_body],
        capture_output=True, text=True,
    )
    return f"opened: {pr_url.stdout.strip()}"


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--config", required=True)
    ap.add_argument("--go", action="store_true", help="actually open PRs (else dry-run)")
    ap.add_argument("--limit", type=int, default=0)
    args = ap.parse_args()

    data = yaml.safe_load(Path(args.config).read_text())
    d = data.get("defaults", {})
    defaults = Defaults(
        fork_dir=Path(d.get("fork_dir", str(Path.home() / "forks"))),
        user_login=d.get("user_login", os.environ.get("USER", "you")),
        branch=d.get("branch", "vendor-cleanup/gitattributes-export-ignore"),
        pr_title=d.get("pr_title", Defaults.pr_title),
        sleep_min=d.get("sleep_min", 10),
        sleep_max=d.get("sleep_max", 20),
    )

    # Per-script git config so we can push over HTTPS via gh's token
    # (no yubikey taps mid-script) and ignore fsck for legacy repos.
    os.environ["GIT_CONFIG_PARAMETERS"] = (
        "'fetch.fsckObjects=false' 'receive.fsckObjects=false' 'transfer.fsckObjects=false' "
        "'url.https://github.com/.insteadOf=git@github.com:' "
        "'credential.helper=' "
        "'credential.https://github.com.helper=!gh auth git-credential'"
    )

    opened = 0
    for t in data.get("targets", []):
        try:
            result = process_target(t, defaults, dry_run=not args.go)
        except Exception as exc:
            result = f"error: {exc}"
        print(f"    -> {result}")
        if args.go and result.startswith("opened:"):
            opened += 1
            if args.limit and opened >= args.limit:
                print(f"hit --limit={args.limit}, stopping")
                break
            time.sleep(random.randint(defaults.sleep_min, defaults.sleep_max))
    return 0


if __name__ == "__main__":
    sys.exit(main())
